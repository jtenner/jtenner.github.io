---
import EditorialLayout from "../layouts/EditorialLayout.astro";
import { getCollection } from "astro:content";
import FeaturedProjects from "../components/FeaturedProjects.astro";
import {
  BLOG_IDENTITY,
  buildHomepageItemListSchema,
  buildWebsiteSchema,
  type JsonLdPayload,
} from "../lib/structuredData";

const allPosts = (await getCollection("posts")).sort(
  (a, b) =>
    new Date(b.data.pubDate).valueOf() - new Date(a.data.pubDate).valueOf(),
);

const categoryParam = Astro.url.searchParams.get("category") ?? "All";
const pageParam = Astro.url.searchParams.get("page") ?? "1";

const categoryFilters = [
  "All",
  ...new Set(allPosts.flatMap((post) => post.data.categories).sort()),
];
const selectedCategory = categoryFilters.includes(categoryParam)
  ? categoryParam
  : "All";
const currentPage = Math.max(1, Number.parseInt(pageParam, 10) || 1);
const postsPerPage = 2;
const totalPosts = allPosts.length;
const totalPages = Math.max(1, Math.ceil(totalPosts / postsPerPage));
const safePage = Math.min(currentPage, totalPages);
const site = Astro.site ?? Astro.url;
const visiblePosts = allPosts.slice(
  (safePage - 1) * postsPerPage,
  safePage * postsPerPage,
);
const jsonLd = [
  buildWebsiteSchema({
    site,
    name: BLOG_IDENTITY.siteName,
    publisher: BLOG_IDENTITY.publisher,
  }),
  buildHomepageItemListSchema({
    site,
    visiblePosts,
  }),
].filter((schema): schema is JsonLdPayload => Boolean(schema));

const pageLink = (category: string, page: number) => {
  const params = new URLSearchParams();

  if (category !== "All") {
    params.set("category", category);
  }

  if (page > 1) {
    params.set("page", String(page));
  }

  const qs = params.toString();
  return qs ? `/?${qs}` : "/";
};
---

<EditorialLayout title="Assembling Me | The Editorial Architect" jsonLd={jsonLd}>
  <div class="fixed top-0 left-0 w-full h-0.5 bg-primary-container z-[60]">
    <div class="h-full bg-primary w-1/3"></div>
  </div>

  <header
    class="fixed top-0 w-full z-50 bg-[#0b1326]/80 backdrop-blur-xl shadow-2xl shadow-[#060e20]/40 border-b border-white/5"
  >
    <div
      class="flex items-center justify-between px-8 py-4 max-w-screen-2xl mx-auto"
    >
      <div class="flex items-center gap-12">
        <a
          class="text-2xl font-black text-primary tracking-tighter font-headline"
          href="/">Assembling Me</a
        >
        <nav class="flex gap-8">
        <a
          class="text-primary border-b-2 border-primary pb-1 font-headline font-bold uppercase tracking-wider text-xs"
          href="/">Blog</a
        >
        <a
          class="text-slate-400 hover:text-slate-100 transition-colors font-headline font-bold uppercase tracking-wider text-xs"
          href="/projects/"
          >Projects</a
        >
        <a
          class="text-slate-400 hover:text-slate-100 transition-colors font-headline font-bold uppercase tracking-wider text-xs"
          href="mailto:tenner.joshua@gmail.com"
          >Contact Me</a
        >
        </nav>
      </div>
    </div>
  </header>

  <main class="pt-32 pb-20">
    <section class="max-w-screen-2xl mx-auto px-8 mb-24">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <div class="lg:col-span-7">
          <p class="text-on-surface-variant text-3xl lg:text-5xl font-light leading-tight max-w-2xl">
            Hey. I'm Josh, and I build things.
          </p>
        </div>
        <div
          class="lg:col-span-5 relative aspect-square bg-surface-container-high rounded-xl overflow-hidden"
        >
          <div
            class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent z-10"
          >
          </div>
          <img
            alt="Cybersecurity Infrastructure"
            class="w-full h-full object-cover grayscale opacity-50 hover:grayscale-0 hover:opacity-100 transition-all duration-700"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuBbmX7MH0f9RUafI7321hXE283WWVRfUJzHqNeunpZQE3VOrvi653fvLzKXDeXL7MkvQnEOHCWcJ-8BK61eZxE9D6rphTuEqxHn7DcZk9Kh_XeCYF20dDmYgvw0C4pBlGkuhhvS61lrSZR45G5PU86Nokd534RuWSccKqabD857iEajm-jSp9Y0VYVk0IUlAUX-GsIWqqmYDm-IhhwhxOJYSKJMD2HeaMhGu0pm3KvgG-5U3ipfX0jeKHJd7rOJZK4oTgwECQ92a6s"
          />
        </div>
      </div>
    </section>

    <section
      class="max-w-screen-2xl mx-auto px-8 grid grid-cols-1 lg:grid-cols-12 gap-16"
    >
      <div class="lg:col-span-8">
        <div
          class="flex items-center justify-between mb-12 py-4 border-y border-outline-variant/15"
        >
          <h2
            class="text-3xl font-black font-headline tracking-tighter uppercase italic"
          >
            Latest Thinking
          </h2>
          <span
            class="text-outline text-[10px] font-bold uppercase tracking-widest font-headline"
            data-posts-count
            >{Math.min((safePage - 1) * postsPerPage + 1, totalPosts)}-{
              Math.min(safePage * postsPerPage, totalPosts)
            } of {totalPosts} Articles</span
          >
        </div>

        <div
          class="grid grid-cols-1 md:grid-cols-2 gap-y-16 gap-x-12"
          data-post-grid
        >
          {
            allPosts.map((post, index) => {
              const categories = post.data.categories ?? [];
              const tag = categories[0] ?? "Systems";
              return (
                <article
                  class={`flex flex-col group cursor-pointer ${index >= postsPerPage ? "hidden" : ""}`}
                  data-post-card
                  data-categories={JSON.stringify(categories)}
                >
                  <a href={`/posts/${post.slug}`} class="flex flex-col h-full">
                    <div class="relative aspect-video mb-6 overflow-hidden bg-surface-container-highest">
                      <img
                        alt={post.data.title}
                        class="w-full h-full object-cover opacity-70 group-hover:opacity-100 group-hover:scale-105 transition-all duration-700"
                        src={post.data.image}
                      />
                      <div class="absolute top-4 right-4 bg-surface/90 backdrop-blur px-2 py-1">
                        <span class="text-[10px] font-bold text-tertiary uppercase tracking-widest font-headline">
                          {tag}
                        </span>
                      </div>
                    </div>
                    <h3 class="text-2xl font-bold font-headline leading-tight mb-4 group-hover:text-primary transition-colors">
                      {post.data.title}
                    </h3>
                    <p class="text-on-surface-variant text-sm leading-relaxed mb-6 font-light">
                      {post.data.description}
                    </p>
	                  <div class="mt-auto flex items-center justify-between pt-4 border-t border-outline-variant/10">
	                      <div class="flex items-center gap-3">
                        <a
                          class="text-on-surface font-bold font-headline text-[10px] uppercase hover:text-primary transition-colors"
                          href={`mailto:${post.data.authorEmail}`}
                        >
                          {post.data.author}
                        </a>
                        <span class="text-outline text-[10px] font-label">
                          {new Intl.DateTimeFormat("en-US", {
                            month: "short",
                            day: "numeric",
                            year: "numeric",
                          }).format(new Date(post.data.pubDate))}
                        </span>
                      </div>
                      <span class="material-symbols-outlined text-primary text-sm group-hover:translate-x-1 transition-transform">
                        arrow_forward
                      </span>
                    </div>
                  </a>
                </article>
              );
            })
          }
        </div>

        <p class="mt-10 text-sm text-outline hidden" data-no-posts>
          No posts found for this category.
        </p>

        <div
          class="mt-14 flex items-center justify-between"
          data-pagination-wrap
        >
          <a
            class="text-outline text-[10px] font-headline font-bold uppercase tracking-[0.2em] hover:text-primary transition-colors"
            data-filter-link
            data-pagination-prev
            href={pageLink(selectedCategory, safePage - 1)}
          >
            ← Prev
          </a>
          <span
            class="text-outline text-[10px] font-headline font-bold uppercase tracking-[0.2em]"
            data-page-indicator>Page {safePage} / {totalPages}</span
          >
          <a
            class="text-outline text-[10px] font-headline font-bold uppercase tracking-[0.2em] hover:text-primary transition-colors"
            data-filter-link
            data-pagination-next
            href={pageLink(selectedCategory, safePage + 1)}
          >
            Next →
          </a>
        </div>

        <div class="mt-6 flex flex-wrap gap-2" data-page-number-group>
          {
            Array.from({ length: totalPages }, (_, index) => index + 1).map(
              (pageNo) => (
                <a
                  class={`px-3 py-1.5 text-[10px] font-headline font-black uppercase tracking-[0.2em] border transition-all ${
                    pageNo === safePage
                      ? "bg-surface-container-high border-primary text-primary"
                      : "border-outline-variant/40 text-outline hover:text-on-surface hover:border-outline"
                  }`}
                  data-filter-link
                  href={pageLink(selectedCategory, pageNo)}
                >
                  {pageNo}
                </a>
              ),
            )
          }
        </div>

        <script is:inline type="module">
          const postsPerPage = 2;
          const postCards = [...document.querySelectorAll("[data-post-card]")];
          const categoryLinks = [
            ...document.querySelectorAll("[data-category-link]"),
          ];
          const countElement = document.querySelector("[data-posts-count]");
          const noPostsElement = document.querySelector("[data-no-posts]");
          const prevLink = document.querySelector("[data-pagination-prev]");
          const nextLink = document.querySelector("[data-pagination-next]");
          const pageIndicator = document.querySelector("[data-page-indicator]");
          const pageNumbers = document.querySelector(
            "[data-page-number-group]",
          );
          const showingCategoryElement = document.querySelector(
            "[data-showing-category]",
          );
          const searchInput = document.querySelector("[data-library-search]");
          const validCategories = new Set(
            categoryLinks.map((link) => link.dataset.category),
          );
          const getCategories = (postCard) => {
            try {
              return JSON.parse(postCard.dataset.categories || "[]");
            } catch {
              return [];
            }
          };

          const pageLink = (category, page, query) => {
            const params = new URLSearchParams();
            if (category !== "All") {
              params.set("category", category);
            }
            const normalizedQuery = query?.trim();
            if (normalizedQuery) {
              params.set("q", normalizedQuery);
            }
            if (page > 1) {
              params.set("page", String(page));
            }
            const qs = params.toString();
            return qs ? `/?${qs}` : "/";
          };

          const getTitle = (postCard) =>
            postCard.querySelector("h3")?.textContent ?? "";
          const getDescription = (postCard) =>
            postCard.querySelectorAll("p")[0]?.textContent ?? "";
          const getAuthor = (postCard) =>
            postCard.querySelectorAll("p")[1]?.textContent ?? "";

          const render = () => {
            const params = new URLSearchParams(window.location.search);
            const requestedCategory = params.get("category") ?? "All";
            const category = validCategories.has(requestedCategory)
              ? requestedCategory
              : "All";
            const normalizedQuery = (params.get("q") ?? "")
              .trim()
              .toLowerCase();
            const currentPage =
              Number.parseInt(params.get("page") ?? "1", 10) || 1;

            if (searchInput) {
              if (searchInput.value !== (params.get("q") ?? "")) {
                searchInput.value = params.get("q") ?? "";
              }
            }

            const filteredCards = postCards.filter((postCard) => {
              const categoryMatch =
                category === "All" ||
                getCategories(postCard).includes(category);
              if (!categoryMatch) return false;
              if (!normalizedQuery) return true;
              const title = getTitle(postCard).toLowerCase();
              const description = getDescription(postCard).toLowerCase();
              const author = getAuthor(postCard).toLowerCase();
              return (
                title.includes(normalizedQuery) ||
                description.includes(normalizedQuery) ||
                author.includes(normalizedQuery)
              );
            });

            const totalPosts = filteredCards.length;
            const totalPages = Math.max(
              1,
              Math.ceil(totalPosts / postsPerPage),
            );
            const safePage = Math.min(Math.max(1, currentPage), totalPages);
            const start = (safePage - 1) * postsPerPage;
            const end = safePage * postsPerPage;
            const url = pageLink(category, safePage, normalizedQuery);
            const currentUrl = `${window.location.pathname}${window.location.search}`;
            if (url !== currentUrl) {
              window.history.replaceState({}, "", url);
            }

            postCards.forEach((post) => post.classList.add("hidden"));
            filteredCards.forEach((post, index) => {
              if (index >= start && index < end) {
                post.classList.remove("hidden");
              }
            });

            if (countElement) {
              if (totalPosts === 0) {
                countElement.textContent = "0-0 of 0 Articles";
              } else {
                countElement.textContent = `${Math.min(start + 1, totalPosts)}-${Math.min(end, totalPosts)} of ${totalPosts} Articles`;
              }
            }

            if (noPostsElement) {
              noPostsElement.classList.toggle("hidden", totalPosts > 0);
            }

            if (prevLink) {
              if (safePage > 1) {
                prevLink.href = pageLink(
                  category,
                  safePage - 1,
                  normalizedQuery,
                );
                prevLink.classList.remove("text-outline/40");
                prevLink.classList.add("hover:text-primary");
              } else {
                prevLink.removeAttribute("href");
                prevLink.classList.add("text-outline/40");
                prevLink.classList.remove("hover:text-primary");
              }
            }

            if (nextLink) {
              if (safePage < totalPages) {
                nextLink.href = pageLink(
                  category,
                  safePage + 1,
                  normalizedQuery,
                );
                nextLink.classList.remove("text-outline/40");
                nextLink.classList.add("hover:text-primary");
              } else {
                nextLink.removeAttribute("href");
                nextLink.classList.add("text-outline/40");
                nextLink.classList.remove("hover:text-primary");
              }
            }

            if (pageIndicator) {
              pageIndicator.textContent = `Page ${safePage} / ${totalPages}`;
            }

            if (pageNumbers) {
              pageNumbers.innerHTML = "";
              for (let pageNo = 1; pageNo <= totalPages; pageNo += 1) {
                const anchor = document.createElement("a");
                anchor.className =
                  "px-3 py-1.5 text-[10px] font-headline font-black uppercase tracking-[0.2em] border transition-all " +
                  (pageNo === safePage
                    ? "bg-surface-container-high border-primary text-primary"
                    : "border-outline-variant/40 text-outline hover:text-on-surface hover:border-outline");
                anchor.href = pageLink(category, pageNo, normalizedQuery);
                anchor.dataset.filterLink = "true";
                anchor.textContent = String(pageNo);
                pageNumbers.appendChild(anchor);
              }
            }

            categoryLinks.forEach((link) => {
              link.href = pageLink(
                link.dataset.category || "All",
                1,
                normalizedQuery,
              );
              const isActive = link.dataset.category === category;
              if (isActive) {
                link.classList.add(
                  "bg-surface-container-high",
                  "border-primary",
                  "text-primary",
                );
                link.classList.remove("text-outline");
              } else {
                link.classList.remove(
                  "bg-surface-container-high",
                  "border-primary",
                  "text-primary",
                );
                link.classList.add("text-outline");
              }
            });

            if (showingCategoryElement) {
              showingCategoryElement.textContent = `Showing: ${category}`;
            }
          };

          const updateQuery = () => {
            const params = new URLSearchParams(window.location.search);
            const requestedCategory = params.get("category") ?? "All";
            const category = validCategories.has(requestedCategory)
              ? requestedCategory
              : "All";
            const query = searchInput?.value?.trim() ?? "";
            const nextUrl = pageLink(category, 1, query);
            if (
              nextUrl !== `${window.location.pathname}${window.location.search}`
            ) {
              window.history.pushState({}, "", nextUrl);
            }
            render();
          };

          document.addEventListener("click", (event) => {
            const anchor = event.target.closest(
              "[data-category-link], [data-filter-link]",
            );
            if (!anchor || !anchor.getAttribute("href")) {
              return;
            }
            event.preventDefault();
            const nextUrl = anchor.getAttribute("href");
            if (!nextUrl) return;
            const currentUrl = `${window.location.pathname}${window.location.search}`;
            if (nextUrl !== currentUrl) {
              window.history.pushState({}, "", nextUrl);
              render();
            }
          });

          if (searchInput) {
            searchInput.addEventListener("input", () => {
              updateQuery();
            });
          }

          window.addEventListener("popstate", () => render());
          render();
        </script>
      </div>

      <aside class="lg:col-span-4 space-y-16">
        <section>
          <h4
            class="text-[10px] font-bold uppercase tracking-widest text-primary font-headline mb-4"
          >
            Categories
          </h4>
          <div class="flex flex-wrap gap-3">
            {
              categoryFilters.map((category) => (
                <a
                  data-category-link
                  data-category={category}
                  class={`px-3 py-2 text-[10px] font-headline font-black uppercase tracking-[0.2em] border border-outline-variant/30 transition-all ${
                    category === selectedCategory
                      ? "bg-surface-container-high border-primary text-primary"
                      : "text-outline"
                  }`}
                  data-filter-link
                  href={pageLink(category, 1)}
                >
                  {category}
                </a>
              ))
            }
          </div>
          <div
            class="text-[10px] text-outline tracking-[0.2em] font-headline uppercase mt-3"
            data-showing-category
          >
            Showing: {selectedCategory}
          </div>
        </section>
        <div
          class="p-8 bg-surface-container-low border-b-2 border-transparent focus-within:border-primary transition-all"
        >
          <h4
            class="text-[10px] font-bold uppercase tracking-widest text-outline font-headline mb-4"
          >
            Library Search
          </h4>
          <div class="relative flex items-center">
            <input
              data-library-search
              class="w-full bg-transparent border-none p-0 focus:ring-0 text-xl font-headline font-medium placeholder:text-outline-variant text-on-surface"
              placeholder="Search topics..."
              type="text"
              autocomplete="off"
            />
            <span class="material-symbols-outlined text-outline">search</span>
          </div>
        </div>
        <FeaturedProjects />
      </aside>
    </section>
  </main>

  <footer class="bg-[#0b1326] w-full border-t border-white/5 mt-16">
    <div
      class="grid grid-cols-1 md:grid-cols-12 gap-12 px-8 py-20 max-w-screen-2xl mx-auto"
    >
      <div class="md:col-span-4 space-y-6">
        <span
          class="font-headline font-black text-primary text-2xl tracking-tighter"
          >DevEditorial</span
        >
        <p class="text-slate-500 font-body text-sm leading-relaxed max-w-xs">
          Analyzing the engineering behind the most scalable systems.
        </p>
      </div>
      <div class="md:col-span-4 flex flex-col gap-4">
        <h5
          class="text-primary font-bold font-headline text-[10px] uppercase tracking-widest"
        >
          Resources
        </h5>
        <a
          class="text-slate-500 hover:text-primary font-body text-sm transition-all"
          href="#">Changelog</a
        >
        <a
          class="text-slate-500 hover:text-primary font-body text-sm transition-all"
          href="#">Privacy Policy</a
        >
      </div>
      <div class="md:col-span-4 flex flex-col items-end justify-between">
        <p
          class="text-slate-600 font-headline text-[10px] uppercase tracking-widest text-right mt-8"
        >
          © 2024 DevEditorial Architect.
        </p>
      </div>
    </div>
  </footer>
</EditorialLayout>
