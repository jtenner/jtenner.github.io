---
import EditorialLayout from "../layouts/EditorialLayout.astro";
---

<EditorialLayout
  title="Cloud Architecture | Assembling Me"
  description="A static demo category layout used for design exploration."
  noindex={true}
>
  <!-- Top Navigation Bar -->
  <nav
    aria-label="Primary"
    class="fixed top-0 w-full z-50 bg-[#0b1326]/80 backdrop-blur-xl shadow-2xl shadow-[#060e20]/40"
  >
    <div
      class="flex items-center justify-between px-8 py-4 max-w-screen-2xl mx-auto"
    >
      <a
        class="text-2xl font-black text-[#7bd0ff] tracking-tighter font-headline"
        href="/"
        >Assembling Me</a
      >
      <div class="flex items-center gap-8 font-headline font-bold uppercase tracking-wider">
        <a
          class="text-primary border-b-2 border-primary pb-1 font-headline font-bold uppercase tracking-wider"
          href="/"
          aria-current="page">Blog</a
        >
        <a
          class="text-slate-400 hover:text-slate-100 transition-colors"
          href="/projects/"
          >Projects</a
        >
        <a
          class="text-slate-400 hover:text-slate-100 transition-colors font-headline font-bold uppercase tracking-wider"
          href="mailto:tenner.joshua@gmail.com"
          >Contact Me</a
        >
      </div>
    </div>
  </nav>
  <main class="pt-32 pb-24" id="main-content">
    <!-- Category Header -->
    <header class="max-w-screen-2xl mx-auto px-8 mb-20">
      <div class="flex flex-col md:flex-row gap-12 items-start">
        <div class="flex-1">
          <div class="flex items-center gap-4 mb-6">
            <span
              class="bg-tertiary/10 text-tertiary px-3 py-1 rounded text-xs font-headline font-bold uppercase tracking-widest"
              >Category</span
            >
            <div class="h-px flex-1 bg-outline-variant/20"></div>
          </div>
          <h1
            class="text-6xl md:text-8xl font-headline font-black text-on-surface tracking-tighter leading-none mb-8"
          >
            Cloud <br /><span class="text-primary">Architecture</span>
          </h1>
          <p class="text-xl text-on-surface-variant max-w-2xl leading-relaxed">
            In-depth blueprints, scaling strategies, and distributed systems
            patterns for the modern cloud-native era. From serverless
            orchestration to multi-region resilience.
          </p>
        </div>
        <div
          class="w-full md:w-1/3 aspect-square bg-surface-container-high rounded-xl relative overflow-hidden group"
        >
          <div
            class="absolute inset-0 bg-gradient-to-tr from-primary/20 to-transparent z-10"
          >
          </div>
          <img
            class="w-full h-full object-cover grayscale opacity-50 group-hover:grayscale-0 group-hover:opacity-100 transition-all duration-700"
            alt="Abstract blue glowing digital server network nodes"
            src="https://lh3.googleusercontent.com/aida-public/AB6AXuA3SiJyon1w9IOwzUz8hg_RP8Th72UXE0-611o1VKho3JFQuYehxeCVVtCTRrhTpbgTxbK-SUHlMih9ZrHI3qkwjWvVJCJzrFzKOhwqNnR_wf6DdfAYfZN8ZtEzZz9PGVmN8oTIdIR7CdOL-R5-pbH4RSTFJ5VZtLnRB_eEafdPHkCnEJC-DOhGXT9rHkTNdsUdS3-E46OtmJtaaEm6HEA6G-iHLfXbWuZ2KJ5Tmrjv5hoTFs6bWz50nEIvaJIDftDy8wbH6jdK2Vc"
          />
        </div>
      </div>
    </header>
    <!-- Filters & Sort -->
    <section class="max-w-screen-2xl mx-auto px-8 mb-12">
      <div
        class="flex flex-wrap items-center justify-between gap-8 py-6 border-y border-outline-variant/15"
      >
        <div class="flex items-center gap-8">
          <div class="flex flex-col gap-1">
            <span
              class="text-[10px] font-headline font-bold uppercase tracking-widest text-outline"
              >Sort By</span
            >
            <div class="flex gap-4">
              <span class="text-primary font-headline font-bold text-sm tracking-wide">Newest</span>
              <span class="text-on-surface-variant font-headline font-bold text-sm tracking-wide">Most Popular</span>
            </div>
          </div>
          <div class="h-8 w-px bg-outline-variant/20"></div>
          <div class="flex flex-col gap-1">
            <span
              class="text-[10px] font-headline font-bold uppercase tracking-widest text-outline"
              >Complexity</span
            >
            <div class="flex gap-4">
              <span class="text-on-surface-variant font-headline font-bold text-sm tracking-wide">Entry</span>
              <span class="text-on-surface-variant font-headline font-bold text-sm tracking-wide">Senior</span>
              <span class="text-on-surface-variant font-headline font-bold text-sm tracking-wide">Staff+</span>
            </div>
          </div>
        </div>
        <div
          class="flex items-center gap-2 text-on-surface-variant font-label text-sm"
        >
          <span class="font-bold text-primary">24</span> Articles Found
        </div>
      </div>
    </section>
    <!-- Article Grid (Asymmetric Layout) -->
    <section class="max-w-screen-2xl mx-auto px-8">
      <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
        <!-- Main Featured Article (Large) -->
        <article class="md:col-span-8 group">
          <div
            class="relative overflow-hidden mb-6 aspect-[16/9] bg-surface-container"
          >
            <img
              class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105 opacity-80 group-hover:opacity-100"
              alt="High tech server room with blue neon lighting"
              src="https://lh3.googleusercontent.com/aida-public/AB6AXuB2fmS9D5KMBefbFOpJAXxtAKt7330ronYo8RIKthaYd9YGhtAf7MNdFLPUYYGcUAPdTFRBBQ28kF0Rwfb3viz1OoL1eZpRivf2TKMZOhLkD1CCKtXDRUqdkiOgezDHcOnmkyQuYqRCcQj96hU401_AbToSOc8glTjNlGtMIVFzTx2HcOlpKpd1N-0NE8rKiogc1w26Wtz17oXMIJF4xceuen6zEX5aDXT_YxEfIodyGb8ze45tn1Z4hhA9QrIc7dVJgLdSuyF_mhc"
            />
            <div
              class="absolute top-6 left-6 bg-surface/90 backdrop-blur-md px-4 py-2 rounded flex items-center gap-2"
            >
              <span
                class="material-symbols-outlined text-primary text-sm"
                style="font-variation-settings: 'FILL' 1;">bolt</span
              >
              <span
                class="text-xs font-headline font-bold uppercase tracking-tighter"
                >Featured Deep-Dive</span
              >
            </div>
          </div>
          <div class="flex items-center gap-4 mb-4">
            <span
              class="text-primary font-headline font-bold text-xs tracking-widest uppercase"
              >Blueprints</span
            >
            <span class="w-1 h-1 rounded-full bg-outline-variant"></span>
            <span class="text-on-surface-variant font-label text-xs"
              >12 Min Read</span
            >
          </div>
          <h2
            class="text-4xl font-headline font-bold leading-tight mb-4 group-hover:text-primary transition-colors"
          >
            Designing for Failure: Implementing Cell-Based Architecture at
            Global Scale
          </h2>
          <p
            class="text-on-surface-variant leading-relaxed text-lg mb-6 max-w-3xl"
          >
            A comprehensive look at how modern hyperscalers isolate failure
            domains through modular cell distribution, moving beyond traditional
            regional deployments.
          </p>
          <div class="flex items-center gap-4">
            <div
              class="w-10 h-10 rounded bg-primary-container flex items-center justify-center"
            >
              <span class="material-symbols-outlined text-primary">person</span>
            </div>
            <div>
              <p class="text-sm font-bold font-headline">Alex Chen</p>
              <p class="text-[10px] uppercase tracking-widest text-outline">
                Principal Architect
              </p>
            </div>
          </div>
        </article>
        <!-- Sidebar Grid Items -->
        <div class="md:col-span-4 flex flex-col gap-12">
          <article class="group">
            <div
              class="aspect-video bg-surface-container-high mb-4 overflow-hidden"
            >
              <img
                class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity"
                alt="Close up of digital circuit board with light"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuBJQkGso9DWKOA-QaeRwC9xCok8lf88sOocHwWtwUBo40FjGAOEpulPNwzVXfAK2w4Y_CiZl4_69C4pWYI-fHph2d3tCF0m6VTQAWUW3Ej8jnzLfLf87KsU2aq4x1VnyA6jj-BCdv3BqAdBmwLdKbgGObXhPBJsJYEIC7Xp2-Ii5MhXQhLeelLiFVqj9jvdX8Ot4ACjHLuSKLJKZ5mVn22-LbluXQu5ByIRhmHL884tvj4Qap3-0eW1DHXbhiikmSYhRCXfR_I_Hq8"
              />
            </div>
            <span
              class="text-tertiary font-headline font-bold text-[10px] tracking-widest uppercase mb-2 block"
              >Case Study</span
            >
            <h3
              class="text-xl font-headline font-bold group-hover:text-primary transition-colors"
            >
              Eventual Consistency in Payment Systems
            </h3>
          </article>
          <article class="group">
            <div
              class="aspect-video bg-surface-container-high mb-4 overflow-hidden"
            >
              <img
                class="w-full h-full object-cover opacity-60 group-hover:opacity-100 transition-opacity"
                alt="Digital representation of secure cloud lock"
                src="https://lh3.googleusercontent.com/aida-public/AB6AXuCrwXarHMWcG4tmQFzDg5fvVILhLayBT9-Lr-3D-L1x0OI4xSJg2qd0ZDNAOw3v6fxUukhjTJTkJAjg-a-7NZ2rBLfI0jso3wHzX9Z2eAw-ZJAZlsT9z0twHXYXjCCUliBOezMtybs255EjAjMT5LjucWRruXVQQBIOk2bKnBqt7F7IvJxAXc1Dlzlim8vv3k0W3mhMt_k1FLCXYGrh-avEBCWrsA0tH4fGI79z_22tZ0QnX8FspK42nAJHHqN-l8MuzJXwyx_jMe8"
              />
            </div>
            <span
              class="text-primary font-headline font-bold text-[10px] tracking-widest uppercase mb-2 block"
              >Security</span
            >
            <h3
              class="text-xl font-headline font-bold group-hover:text-primary transition-colors"
            >
              Zero-Trust Patterns for Multi-Cloud Data Mesh
            </h3>
          </article>
        </div>
        <!-- Secondary Row -->
        <div
          class="md:col-span-12 grid grid-cols-1 md:grid-cols-3 gap-12 mt-12"
        >
          <article
            class="p-8 bg-surface-container-low hover:bg-surface-container transition-colors group"
          >
            <span
              class="text-on-surface-variant font-headline font-bold text-[10px] tracking-widest uppercase mb-4 block"
              >Tutorial</span
            >
            <h3
              class="text-2xl font-headline font-bold mb-4 group-hover:text-primary transition-colors leading-snug"
            >
              Kubernetes Control Planes: Beyond the Basics
            </h3>
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              Hardening your master nodes and optimizing etcd performance in
              production environments.
            </p>
            <div class="flex items-center gap-3">
              <span
                class="text-xs font-bold text-primary tracking-widest uppercase font-headline"
                >Read Article</span
              >
              <span
                class="material-symbols-outlined text-sm text-primary group-hover:translate-x-1 transition-transform"
                >arrow_forward</span
              >
            </div>
          </article>
          <article
            class="p-8 bg-surface-container-low hover:bg-surface-container transition-colors group"
          >
            <span
              class="text-on-surface-variant font-headline font-bold text-[10px] tracking-widest uppercase mb-4 block"
              >Philosophy</span
            >
            <h3
              class="text-2xl font-headline font-bold mb-4 group-hover:text-primary transition-colors leading-snug"
            >
              The False Promise of Infinite Scalability
            </h3>
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              Why vertical scaling still has a place in the era of containerized
              horizontal sprawl.
            </p>
            <div class="flex items-center gap-3">
              <span
                class="text-xs font-bold text-primary tracking-widest uppercase font-headline"
                >Read Article</span
              >
              <span
                class="material-symbols-outlined text-sm text-primary group-hover:translate-x-1 transition-transform"
                >arrow_forward</span
              >
            </div>
          </article>
          <article
            class="p-8 bg-surface-container-low hover:bg-surface-container transition-colors group"
          >
            <span
              class="text-on-surface-variant font-headline font-bold text-[10px] tracking-widest uppercase mb-4 block"
              >Infrastructure</span
            >
            <h3
              class="text-2xl font-headline font-bold mb-4 group-hover:text-primary transition-colors leading-snug"
            >
              Terraform vs Pulumi: State Management
            </h3>
            <p class="text-on-surface-variant text-sm mb-6 leading-relaxed">
              A deep dive into how state files are handled at scale across
              different IaC providers.
            </p>
            <div class="flex items-center gap-3">
              <span
                class="text-xs font-bold text-primary tracking-widest uppercase font-headline"
                >Read Article</span
              >
              <span
                class="material-symbols-outlined text-sm text-primary group-hover:translate-x-1 transition-transform"
                >arrow_forward</span
              >
            </div>
          </article>
        </div>
      </div>
    </section>
    <!-- Pagination -->
    <section class="max-w-screen-2xl mx-auto px-8 mt-24">
      <div class="flex items-center justify-center gap-2">
        <span
          aria-hidden="true"
          class="w-10 h-10 flex items-center justify-center rounded border border-outline-variant/30 text-outline"
        >
          <span class="material-symbols-outlined">chevron_left</span>
        </span>
        <span
          class="w-10 h-10 flex items-center justify-center rounded bg-primary text-on-primary font-bold font-headline"
          >1</span
        >
        <span
          class="w-10 h-10 flex items-center justify-center rounded text-on-surface-variant font-headline font-bold"
          >2</span
        >
        <span
          class="w-10 h-10 flex items-center justify-center rounded text-on-surface-variant font-headline font-bold"
          >3</span
        >
        <span class="px-2 text-outline">...</span>
        <span
          class="w-10 h-10 flex items-center justify-center rounded text-on-surface-variant font-headline font-bold"
          >8</span
        >
        <span
          aria-hidden="true"
          class="w-10 h-10 flex items-center justify-center rounded border border-outline-variant/30 text-outline"
        >
          <span class="material-symbols-outlined">chevron_right</span>
        </span>
      </div>
    </section>
  </main>
  <!-- Footer -->
  <footer class="w-full border-t border-[#45464d]/15 bg-[#0b1326]">
    <div
      class="grid grid-cols-1 md:grid-cols-3 gap-12 px-12 py-20 max-w-screen-2xl mx-auto"
    >
      <div class="space-y-6">
        <div
          class="font-space-grotesk font-bold text-[#7bd0ff] text-2xl tracking-tighter"
        >
          Assembling Me
        </div>
        <p
          class="text-slate-500 font-inter text-sm antialiased max-w-xs leading-relaxed"
        >
          A practical blog on WebAssembly tooling, compiler systems, and robust software architecture.
        </p>
      </div>
      <div class="grid grid-cols-2 gap-8">
        <div class="space-y-4">
          <div
            class="text-[#7bd0ff] font-semibold text-sm uppercase tracking-widest font-headline"
          >
            Explore
          </div>
          <div class="flex flex-col gap-3 font-inter text-sm">
            <a
              class="text-slate-500 hover:text-[#7bd0ff] hover:translate-x-1 transition-all duration-300"
              href="/changelog/">Changelog</a
            >
            <a
              class="text-slate-500 hover:text-[#7bd0ff] hover:translate-x-1 transition-all duration-300"
              href="/rss.xml">RSS Feed</a
            >
            <a
              class="text-slate-500 hover:text-[#7bd0ff] hover:translate-x-1 transition-all duration-300"
              href="/?category=Open+Source">Open Source</a
            >
          </div>
        </div>
        <div class="space-y-4">
          <div
            class="text-[#7bd0ff] font-semibold text-sm uppercase tracking-widest font-headline"
          >
            Legal
          </div>
          <div class="flex flex-col gap-3 font-inter text-sm">
            <a
              class="text-slate-500 hover:text-[#7bd0ff] hover:translate-x-1 transition-all duration-300"
              href="/privacy/">Privacy Policy</a
            >
            <a
              class="text-slate-500 hover:text-[#7bd0ff] hover:translate-x-1 transition-all duration-300"
              href="/terms/">Terms of Use</a
            >
            <a
              class="text-slate-500 hover:text-[#7bd0ff] hover:translate-x-1 transition-all duration-300"
              href="/cookies/">Cookie Policy</a
            >
          </div>
        </div>
      </div>
      <div class="space-y-6">
        <div
          class="text-[#7bd0ff] font-semibold text-sm uppercase tracking-widest font-headline"
        >
          Newsletter
        </div>
        <div class="flex flex-col gap-3 text-sm">
          <a class="text-primary hover:text-[#7bd0ff] transition-colors" href="/rss.xml">Subscribe via RSS</a>
          <a class="text-primary hover:text-[#7bd0ff] transition-colors" href="mailto:tenner.joshua@gmail.com">Contact Joshua</a>
        </div>
        <p class="text-slate-600 text-[10px] leading-relaxed">
          © 2026 Assembling Me.
        </p>
      </div>
    </div>
  </footer>
</EditorialLayout>
