              <span
                class="material-symbols-outlined text-2xl"
                style="font-variation-settings: 'FILL' 1;">favorite</span
              >
              <span class="text-[10px] font-black tracking-widest">1.2K</span>
            </div>
            <div class="flex flex-col items-center gap-2">
