---
import EditorialLayout from "../layouts/EditorialLayout.astro";
---

<EditorialLayout
  title="Page Not Found | Assembling Me"
  description="The page you requested does not exist."
  noindex={true}
>
  <main class="max-w-4xl mx-auto px-8 py-32" id="main-content">
    <p class="text-primary font-headline font-black text-[10px] uppercase tracking-[0.22em]">
      404
    </p>
    <h1 class="mt-4 text-5xl font-black font-headline tracking-tighter text-on-surface">
      Page not found
    </h1>
    <p class="mt-6 max-w-2xl text-lg leading-8 text-on-surface-variant">
      The link may be stale, or the page may have moved while the site was being cleaned up.
    </p>
    <div class="mt-10 flex flex-wrap gap-4">
      <a
        class="rounded-md bg-primary px-5 py-3 text-[10px] font-headline font-black uppercase tracking-[0.2em] text-on-primary"
        href="/"
      >
        Back to Home
      </a>
      <a
        class="rounded-md border border-outline-variant/30 px-5 py-3 text-[10px] font-headline font-black uppercase tracking-[0.2em] text-on-surface"
        href="/projects/"
      >
        Browse Projects
      </a>
    </div>
  </main>
</EditorialLayout>
