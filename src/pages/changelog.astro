---
import EditorialLayout from "../layouts/EditorialLayout.astro";
---

<EditorialLayout
  title="Changelog | Assembling Me"
  description="Recent site and publishing changes for Assembling Me."
>
  <main class="max-w-4xl mx-auto px-8 py-24" id="main-content">
    <h1 class="text-5xl font-black font-headline tracking-tighter text-on-surface">
      Changelog
    </h1>
    <div class="mt-12 space-y-10">
      <section class="border-l-2 border-primary pl-6">
        <p class="text-[10px] font-headline font-black uppercase tracking-[0.22em] text-primary">
          2026-03-24
        </p>
        <h2 class="mt-3 text-2xl font-headline font-black text-on-surface">
          SEO and accessibility cleanup
        </h2>
        <p class="mt-3 text-on-surface-variant leading-7">
          Added build-time sitemap generation, crawler discovery files, canonical metadata,
          Open Graph metadata, a manifest, a favicon, a 404 page, and keyboard/screen-reader
          improvements across the site.
        </p>
      </section>
      <section class="border-l-2 border-outline-variant/30 pl-6">
        <p class="text-[10px] font-headline font-black uppercase tracking-[0.22em] text-primary">
          2026-03-24
        </p>
        <h2 class="mt-3 text-2xl font-headline font-black text-on-surface">
          Initial public posts
        </h2>
        <p class="mt-3 text-on-surface-variant leading-7">
          Published the first wave of blog posts and project pages covering WebAssembly,
          agent metadata, and AssemblyScript tooling work.
        </p>
      </section>
    </div>
  </main>
</EditorialLayout>
