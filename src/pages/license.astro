---
import EditorialLayout from "../layouts/EditorialLayout.astro";
---

<EditorialLayout
  title="Content License | Assembling Me"
  description="Content licensing information for Assembling Me."
>
  <main class="max-w-4xl mx-auto px-8 py-24" id="main-content">
    <article class="prose prose-invert prose-lg max-w-none">
      <h1>Content License</h1>
      <p>
        Unless otherwise noted, original writing and site content on Assembling Me are
        © Joshua Tenner. Rights are reserved.
      </p>
      <h2>Code snippets</h2>
      <p>
        Small code examples may be quoted for reference with attribution. For broader reuse of
        articles, images, or larger excerpts, ask first.
      </p>
      <h2>Project repositories</h2>
      <p>
        Open source project repositories linked from this site may be licensed separately. Check the
        license files in those repositories for the controlling terms.
      </p>
    </article>
  </main>
</EditorialLayout>
