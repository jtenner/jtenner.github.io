---
import EditorialLayout from "../layouts/EditorialLayout.astro";
---

<EditorialLayout
  title="Cookie Policy | Assembling Me"
  description="Cookie policy for Assembling Me."
>
  <main class="max-w-4xl mx-auto px-8 py-24" id="main-content">
    <article class="prose prose-invert prose-lg max-w-none">
      <h1>Cookie Policy</h1>
      <p>
        Assembling Me does not currently set first-party application cookies for accounts,
        comments, or personalization.
      </p>
      <h2>Infrastructure and browser behavior</h2>
      <p>
        Hosting providers, CDNs, or third-party asset providers may use standard web delivery
        mechanisms that include cookies or similar request handling on their side.
      </p>
      <h2>Future updates</h2>
      <p>
        If the site adds analytics, subscriptions, or interactive features that depend on cookies,
        this page should be updated before or when those features go live.
      </p>
    </article>
  </main>
</EditorialLayout>
