---
import EditorialLayout from "../../layouts/EditorialLayout.astro";
import { type CollectionEntry, getCollection } from "astro:content";
import {
  BLOG_IDENTITY,
  buildBlogPostingSchema,
  buildBreadcrumbListSchema,
  type JsonLdPayload,
} from "../../lib/structuredData";

export async function getStaticPaths() {
  const posts = await getCollection("posts");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: { post },
  }));
}

const { post } = Astro.props as { post: CollectionEntry<"posts"> };
const { Content } = await post.render();

const site = Astro.site ?? Astro.url;
const jsonLd = [
  buildBlogPostingSchema({
    site,
    post,
    publisher: BLOG_IDENTITY.publisher,
  }),
  buildBreadcrumbListSchema({
    site,
    postTitle: post.data.title,
    postSlug: post.slug,
  }),
].filter((schema): schema is JsonLdPayload => Boolean(schema));

const published = new Intl.DateTimeFormat("en-US", {
  month: "short",
  day: "numeric",
  year: "numeric",
}).format(post.data.pubDate);
---

<EditorialLayout
  title={`${post.data.title} | Assembling Me`}
  description={post.data.description}
  image={post.data.image}
  jsonLd={jsonLd}
  openGraphType="article"
>
  <header
    class="fixed top-0 w-full z-50 bg-[#0b1326]/80 backdrop-blur-xl shadow-2xl shadow-[#060e20]/40 border-b border-white/5"
  >
    <div
      class="flex items-center justify-between px-8 py-4 max-w-screen-2xl mx-auto"
    >
      <a
        class="text-2xl font-black text-[#7bd0ff] tracking-tighter font-headline"
        href="/"
      >
        Assembling Me
      </a>
      <nav class="flex gap-8" aria-label="Primary">
        <a
          class="text-primary border-b-2 border-primary pb-1 font-headline font-bold uppercase tracking-wider text-xs"
          href="/"
          aria-current="page"
        >
          Blog
        </a>
        <a
          class="text-slate-400 hover:text-slate-100 transition-colors font-headline font-bold uppercase tracking-wider text-xs"
          href="/projects/"
          >Projects</a
        >
        <a
          class="text-slate-400 hover:text-slate-100 transition-colors font-headline font-bold uppercase tracking-wider text-xs"
          href="mailto:tenner.joshua@gmail.com"
        >
          Contact Me
        </a>
      </nav>
    </div>
  </header>
  <main class="pt-28 pb-16 max-w-4xl mx-auto px-8" id="main-content">
	    <article class="prose prose-invert prose-lg max-w-none [&_p]:my-6 [&_p]:leading-8">
      <h1
        class="text-4xl md:text-6xl font-black font-headline tracking-tighter text-on-surface"
      >
        {post.data.title}
      </h1>
      <p class="text-sm text-outline uppercase tracking-[0.2em]">
        {post.data.categories.join(", ")} • <a
          class="hover:text-primary transition-colors"
          href={`mailto:${post.data.authorEmail}`}
        >{post.data.author}</a> • {published}
      </p>
      <img
        class="w-full rounded-lg my-8"
        src={post.data.image}
        alt={post.data.title}
      />
      <Content />
    </article>
  </main>
</EditorialLayout>
