---
import type { CollectionEntry } from "astro:content";
import { parseGithubReference } from "../lib/github";

type Props = {
  project: CollectionEntry<"projects">;
};

const { project } = Astro.props as Props;
const github = parseGithubReference(project.data.github);
---

<article class="rounded-lg border border-outline-variant/20 p-5 bg-surface-container-low">
  <div class="flex items-center gap-2 flex-wrap">
    <a
      class="font-headline font-black text-on-surface text-sm uppercase tracking-[0.08em] hover:text-primary transition-colors"
      href={project.data.projectUrl}
    >
      {project.data.title}
    </a>
    <a
      href={github.ownerUrl ?? project.data.github}
      class="text-xs text-outline uppercase tracking-widest font-headline font-normal hover:text-on-surface transition-colors"
    >
      {github.owner}
    </a>
  </div>
  <p class="mt-2 text-xs text-outline-variant font-mono">
    <a
      href={project.data.latestReleaseUrl}
      class="hover:text-outline transition-colors"
    >
      {project.data.semver}
    </a>
  </p>
  <p class="mt-2 text-sm text-outline leading-relaxed">
    {project.data.description}
  </p>
  <a
    href={`/projects/${project.slug}`}
    class="mt-3 inline-block text-xs text-outline transition-colors"
  >
    View details →
  </a>
</article>
