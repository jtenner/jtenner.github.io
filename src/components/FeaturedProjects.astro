---
import { getCollection } from "astro:content";
import ProjectCard from "./ProjectCard.astro";

const featuredProjects = (await getCollection("projects"))
  .filter((project) => project.data.featured !== undefined)
  .sort((a, b) => {
    const aPriority = a.data.featured ?? -1;
    const bPriority = b.data.featured ?? -1;
    if (aPriority !== bPriority) {
      return bPriority - aPriority;
    }
    return a.slug.localeCompare(b.slug);
  })
  .slice(0, 4);
---

<section>
  <h4
    class="text-lg font-black uppercase tracking-[0.16em] text-on-surface font-headline mb-6 flex items-center gap-2"
  >
    <span class="w-2 h-2 bg-primary rounded-full"></span>Featured projects
  </h4>

  <div class="space-y-4">
    {featuredProjects.length === 0 && (
      <p class="text-sm text-outline">
        Add projects in <code class="font-mono">src/content/projects</code> to
        populate this section.
      </p>
    )}

    {featuredProjects.map((project) => <ProjectCard project={project} />)}
  </div>
</section>
