---
import { getCollection } from "astro:content";

const featuredProjects = (await getCollection("projects"))
  .filter((project) => project.data.featured !== undefined)
  .sort((a, b) => {
    const aPriority = a.data.featured ?? -1;
    const bPriority = b.data.featured ?? -1;
    if (aPriority !== bPriority) {
      return bPriority - aPriority;
    }
    return a.slug.localeCompare(b.slug);
  })
  .slice(0, 4);
---

<section>
  <h4
    class="text-lg font-black uppercase tracking-[0.16em] text-on-surface font-headline mb-6 flex items-center gap-2"
  >
    <span class="w-2 h-2 bg-primary rounded-full"></span>Featured projects
  </h4>

  <div class="space-y-4">
    {featuredProjects.length === 0 && (
      <p class="text-sm text-outline">
        Add projects in <code class="font-mono">src/content/projects</code> to
        populate this section.
      </p>
    )}

    {featuredProjects.map((project) => (
      <article class="rounded-lg border border-outline-variant/20 p-5 bg-surface-container-low">
        <a
          class="font-headline font-black text-on-surface text-sm uppercase tracking-[0.08em] hover:text-primary transition-colors"
          href={`/projects/${project.slug}`}
        >
          {project.data.title}
        </a>
        <p class="mt-2 text-xs text-outline-variant font-mono">
          <a
            href={project.data.latestReleaseUrl}
            class="hover:text-outline transition-colors"
          >
            {project.data.semver}
          </a>
        </p>
        <p class="mt-2 text-sm text-outline leading-relaxed">
          {project.data.description}
        </p>
        <p class="mt-2 text-xs text-outline uppercase tracking-widest font-headline">
          <a
            href={`https://github.com/${project.data.github.trim().replace(/^@/, "")}`}
            class="hover:text-on-surface transition-colors"
          >
            @{project.data.github.trim().replace(/^@/, "")}
          </a>
        </p>
        <a
          href={`/projects/${project.slug}`}
          class="mt-3 inline-block text-xs text-outline transition-colors"
        >
          View details →
        </a>
      </article>
    ))}
  </div>
</section>
