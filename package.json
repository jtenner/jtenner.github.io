{
  "name": "stitch-astro-blog",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "astro dev --host 0.0.0.0",
    "build": "astro build",
    "check:rss": "bun run scripts/check-rss.mjs",
    "preview": "astro preview",
    "format": "biome format . --write && prettier \"src/**/*.astro\" --write",
    "format:check": "biome format . && prettier --check \"src/**/*.astro\""
  },
  "dependencies": {
    "@astrojs/rss": "^4.0.17",
    "@astrojs/sitemap": "3.2.1",
    "astro": "^4.16.0"
  },
  "devDependencies": {
    "@astrojs/tailwind": "^6.0.0",
    "@biomejs/biome": "^2.4.8",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tailwindcss/forms": "^0.5.7",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "tailwindcss": "^3.4.15"
  }
}
